# =============================================
# ResCue AI — .gitignore
# =============================================

# ── Dependencies ────────────────────────────
node_modules/
frontend/node_modules/

# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Environment & Secrets ───────────────────
.env
backend/.env
frontend/.env
backend/firebase-service-account.json
backend/ca.pem

# ── Legacy Model Stubs (replaced by Groq API) ─
Info_Model/
Severity_Model/
_Classes_Model/

# ── Build Artifacts ─────────────────────────
frontend/build/
frontend/coverage/

# ── OS Files ────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── IDE ─────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Scraped Data ────────────────────────────
OnlyReddit/reddit_images/
OnlyReddit/vocab.txt
OnlyBlueSky/vocab.txt

# ── Logs ────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Project Description Image ───────────────
Project Description.jpeg

# ── Stray files ─────────────────────────────
git
